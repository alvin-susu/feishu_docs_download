# 飞书开放平台应用配置
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_VERIFICATION_TOKEN=your_verification_token_here
FEISHU_ENCRYPT_KEY=your_encrypt_key_here

# 服务器配置
PORT=3000
HOST=localhost

# 索引配置
INDEX_UPDATE_INTERVAL=3600000  # 索引更新间隔（毫秒）
ENABLE_AUTO_INDEX=true          # 是否自动更新索引

# 功能开关
ENABLE_DOCUMENT_LOCATOR=true    # 启用文档定位功能
ENABLE_CONTENT_SEARCHER=true    # 启用内容搜索功能
ENABLE_AUTO_ARCHIVER=true       # 启用自动归档功能
ENABLE_MEETING_ASSISTANT=true   # 启用会议助手功能

# 性能配置
MAX_SEARCH_RESULTS=10           # 最大搜索结果数
MAX_TODO_LENGTH=200             # 待办事项最大长度
CACHE_ENABLED=true              # 启用缓存
CACHE_TTL=3600000               # 缓存过期时间（毫秒）

# 日志配置
LOG_LEVEL=info                  # 日志级别: debug, info, warn, error
LOG_FILE_PATH=./logs/app.log    # 日志文件路径
