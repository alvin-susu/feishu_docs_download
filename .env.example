# =====================================
# 🔒 飞书知识库智能助手 - 安全配置模板
# =====================================
# ⚠️ 重要安全提示:
# - 请复制此文件为 .env 并填入真实配置
# - 永远不要将 .env 文件提交到Git仓库
# - 永远不要在代码中硬编码凭证
# - 定期更换密钥和凭证
# - 使用强密码和随机字符串

# =====================================
# 🔑 飞书开放平台应用配置
# =====================================
# 从飞书开放平台获取: https://open.feishu.cn/
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# 事件回调验证 (如果使用事件回调功能)
FEISHU_VERIFICATION_TOKEN=your_verification_token_here
FEISHU_ENCRYPT_KEY=your_encrypt_key_here

# =====================================
# 🔐 数据加密配置 (必须设置!)
# =====================================
# ⚠️ 安全要求: 必须设置此环境变量，否则应用无法启动
# 生成方法:
#   openssl rand -hex 32
#   或
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=please_generate_32_character_random_string_here

# =====================================
# 🌐 服务器配置
# =====================================
PORT=3000
HOST=localhost

# =====================================
# 📊 索引配置
# =====================================
INDEX_UPDATE_INTERVAL=3600000  # 索引更新间隔（毫秒）
ENABLE_AUTO_INDEX=true          # 是否自动更新索引

# =====================================
# ⚙️ 功能开关
# =====================================
ENABLE_DOCUMENT_LOCATOR=true    # 启用文档定位功能
ENABLE_CONTENT_SEARCHER=true    # 启用内容搜索功能
ENABLE_AUTO_ARCHIVER=true       # 启用自动归档功能
ENABLE_MEETING_ASSISTANT=true   # 启用会议助手功能

# =====================================
# ⚡ 性能配置
# =====================================
MAX_SEARCH_RESULTS=10           # 最大搜索结果数
MAX_TODO_LENGTH=200             # 待办事项最大长度
CACHE_ENABLED=true              # 启用缓存
CACHE_TTL=3600000               # 缓存过期时间（毫秒）

# =====================================
# 📝 日志配置
# =====================================
# 日志级别: debug(开发), info(正常), warn(警告), error(错误)
# ⚠️ 生产环境请使用 info 或 warn，不要使用 debug
LOG_LEVEL=info                  # 日志级别: debug, info, warn, error
LOG_FILE_PATH=./logs/app.log    # 日志文件路径

# =====================================
# 🛡️ 安全配置 (推荐)
# =====================================
# 启用请求签名验证
ENABLE_SIGNATURE_VERIFICATION=true

# 启用速率限制
ENABLE_RATE_LIMITING=true

# 最大请求频率 (每分钟)
MAX_REQUESTS_PER_MINUTE=60

# =====================================
# 🔧 调试配置 (仅开发环境)
# =====================================
# 调试模式 (生产环境必须设为false)
DEBUG=false

# 详细错误信息 (生产环境必须设为false)
VERBOSE_ERROR_LOGS=false

# =====================================
# 📋 安全密钥生成方法
# =====================================
# 1. 数据加密密钥 (ENCRYPTION_KEY):
#    openssl rand -hex 32
#    或
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. 验证令牌 (FEISHU_VERIFICATION_TOKEN):
#    openssl rand -hex 16
#
# 3. 加密密钥 (FEISHU_ENCRYPT_KEY):
#    openssl rand -hex 32
#    或从飞书开放平台获取

# =====================================
# ⚠️ 重要安全提醒
# =====================================
# 1. ✅ 定期更换所有密钥和凭证 (建议每3个月)
# 2. ✅ 使用强密码和随机字符串 (至少32字符)
# 3. ✅ 不要在不同环境使用相同凭证
# 4. ✅ 监控异常API调用活动
# 5. ✅ 及时撤销不再使用的凭证
# 6. ✅ 生产环境必须使用 LOG_LEVEL=info 或 warn
# 7. ✅ 不要在公共网络暴露管理端口