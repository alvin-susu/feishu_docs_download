{
  "app": {
    "name": "飞书知识库智能助手",
    "version": "1.0.0",
    "description": "OpenClaw与飞书机器人双向联动插件"
  },
  "feishu": {
    "apiBaseUrl": "https://open.feishu.cn/open-apis",
    "timeout": 30000,
    "retryAttempts": 3,
    "retryDelay": 1000
  },
  "indexer": {
    "indexPath": "./data/index.json",
    "autoUpdate": true,
    "updateInterval": 3600000,
    "maxIndexAge": 604800000,
    "enableIncrementalUpdate": true
  },
  "features": {
    "documentLocator": {
      "enabled": true,
      "maxResults": 10,
      "enableSimilarity": true,
      "similarityThreshold": 0.3
    },
    "contentSearcher": {
      "enabled": true,
      "maxResults": 5,
      "excerptLength": 150,
      "enableAdvancedSearch": true
    },
    "autoArchiver": {
      "enabled": true,
      "defaultCategory": "常规文档",
      "confidenceThreshold": 0.5,
      "enableBatchCreate": true
    },
    "meetingAssistant": {
      "enabled": true,
      "maxTodosPerMessage": 5,
      "maxKeyPoints": 10,
      "enableAutoGenerate": false
    }
  },
  "performance": {
    "cacheEnabled": true,
    "cacheTTL": 3600000,
    "maxConcurrentRequests": 10,
    "requestTimeout": 30000
  },
  "logging": {
    "level": "info",
    "filePath": "./logs/app.log",
    "maxFiles": 10,
    "maxSize": "10M"
  },
  "security": {
    "enableRateLimit": true,
    "maxRequestsPerMinute": 100,
    "enableCors": true,
    "allowedOrigins": ["*"]
  }
}
